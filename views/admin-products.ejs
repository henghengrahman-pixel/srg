<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Kelola Produk - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><div class='admin-layout'><aside class='sidebar'><div class='brand'>Teman<span>Belanja</span></div><nav class='side-nav'><a href='/admin'>Dashboard</a><a class='active' href='/admin/products'>Kelola Produk</a><a href='/admin/products/new'>Tambah Produk</a><a href='/admin/articles'>Kelola Artikel</a><a href='/admin/articles/new'>Tulis Artikel</a><a href='/admin/logout'>Logout</a></nav></aside><main><div class='section-head'><div><h2>Kelola Produk</h2><p>Atur produk, gambar, video, harga, deskripsi, ukuran, dan material.</p></div><a class='btn' href='/admin/products/new'>Tambah Produk</a></div><% if (products.length === 0) { %><div class='empty'>Belum ada produk.</div><% } else { %><div class='table-list'><% products.forEach(p => { %><div class='item-row'><div class='item-thumb'><% if (p.image) { %><img src='/uploads/<%= p.image %>' alt='<%= p.title %>'><% } else if (p.image_url) { %><img src='<%= p.image_url %>' alt='<%= p.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=600&q=80' alt='<%= p.title %>'><% } %></div><div class='item-content'><h3><%= p.title %></h3><p><%= p.category || '-' %> • Rp <%= Number(p.price || 0).toLocaleString('id-ID') %></p></div><div class='item-actions'><a class='btn' href='/admin/products/edit/<%= p.id %>'>Edit</a><form method='POST' action='/admin/products/delete/<%= p.id %>' data-confirm='Hapus produk ini?'><button type='submit' class='btn-danger'>Hapus</button></form></div></div><% }) %></div><% } %></main></div></div><script src='/public/main.js'></script></body></html>