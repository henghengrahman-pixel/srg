<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title><%= mode === 'edit' ? 'Edit Artikel' : 'Tulis Artikel' %> - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><div class='admin-layout'><aside class='sidebar'><div class='brand'>Teman<span>Belanja</span></div><nav class='side-nav'><a href='/admin'>Dashboard</a><a href='/admin/products'>Kelola Produk</a><a href='/admin/products/new'>Tambah Produk</a><a class='active' href='/admin/articles'>Kelola Artikel</a><a href='/admin/articles/new'>Tulis Artikel</a><a href='/admin/logout'>Logout</a></nav></aside><main><div class='panel'><div class='section-head' style='margin-top:0'><div><h2><%= mode === 'edit' ? 'Edit Artikel' : 'Tulis Artikel Baru' %></h2><p>Bangun halaman artikel yang rapi, elegan, dan nyaman dibaca.</p></div></div><form class='form' method='POST' enctype='multipart/form-data' action='<%= mode === "edit" ? "/admin/articles/update/" + article.id : "/admin/articles" %>'><input name='title' placeholder='Judul artikel' value='<%= article ? article.title : "" %>' required><input name='excerpt' placeholder='Ringkasan artikel' value='<%= article ? article.excerpt : "" %>'><div class='form-grid'><div><input type='file' name='thumbnail' accept='image/*'><div class='small-note'>Upload thumbnail manual</div></div><div><input name='thumbnail_url' placeholder='Atau masukkan link thumbnail' value='<%= article ? article.thumbnail_url : "" %>'><div class='small-note'>Link thumbnail manual</div></div></div><textarea name='content' placeholder='Isi artikel lengkap'><%= article ? article.content : "" %></textarea><div class='top-actions'><button type='submit' class='btn'><%= mode === 'edit' ? 'Update Artikel' : 'Simpan Artikel' %></button><a href='/admin/articles' class='btn-secondary'>Kembali</a></div></form></div></main></div></div></body></html>