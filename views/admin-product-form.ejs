<%- include('partials/head', { meta }) %>
<section class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-logo">Lux<span>Affiliate</span></div>
    <a href="/secure-admin-dashboard-rmz9x">Dashboard</a>
    <a href="/secure-admin-products-rmz9x" class="active">Produk</a>
    <a href="/secure-admin-articles-rmz9x">Artikel</a>
    <form action="/secure-admin-logout-rmz9x" method="POST"><button class="btn btn-dark full-btn" type="submit">Logout</button></form>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar"><h1><%= product ? 'Edit Produk' : 'Tambah Produk' %></h1></div>
    <form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data" class="admin-form-grid glass-card">
      <div><label>Nama Produk</label><input type="text" name="name" value="<%= product?.name || '' %>" required></div>
      <div><label>Slug</label><input type="text" name="slug" value="<%= product?.slug || '' %>"></div>
      <div class="full-span"><label>Deskripsi Singkat</label><textarea name="shortDesc" rows="3" required><%= product?.shortDesc || '' %></textarea></div>
      <div class="full-span"><label>Konten Detail (HTML diperbolehkan)</label><textarea name="content" rows="8"><%= product?.content || '' %></textarea></div>
      <div><label>Harga</label><input type="number" name="price" value="<%= product?.price || 0 %>" required></div>
      <div><label>Harga Coret</label><input type="number" name="comparePrice" value="<%= product?.comparePrice || 0 %>"></div>
      <div><label>Kategori</label><input type="text" name="category" value="<%= product?.category || '' %>" required></div>
      <div><label>Brand</label><input type="text" name="brand" value="<%= product?.brand || '' %>"></div>
      <div><label>Affiliate Link Shopee</label><input type="url" name="affiliateUrl" value="<%= product?.affiliateUrl || '' %>" required></div>
      <div><label>Nama Toko Shopee</label><input type="text" name="shopeeStore" value="<%= product?.shopeeStore || '' %>"></div>
      <div><label>Badge</label><input type="text" name="badge" value="<%= product?.badge || '' %>" placeholder="BESTSELLER / HOT"></div>
      <div><label>Rating</label><input type="number" step="0.1" name="rating" value="<%= product?.rating || 4.8 %>"></div>
      <div><label>Terjual</label><input type="text" name="sold" value="<%= product?.sold || '' %>" placeholder="2rb+"></div>
      <div><label>URL Gambar</label><input type="url" name="imageUrl" value="<%= product?.image || '' %>"></div>
      <div><label>Upload Gambar</label><input type="file" name="imageFile" accept="image/*"></div>
      <div class="full-span"><label>Gallery URL (1 baris 1 link)</label><textarea name="gallery" rows="5"><%= product?.gallery?.join('\n') || '' %></textarea></div>
      <div><label>SEO Title</label><input type="text" name="seoTitle" value="<%= product?.seoTitle || '' %>"></div>
      <div><label>SEO Description</label><input type="text" name="seoDescription" value="<%= product?.seoDescription || '' %>"></div>
      <div class="full-span"><label>Keywords</label><input type="text" name="keywords" value="<%= product?.keywords || '' %>"></div>
      <label class="check-line"><input type="checkbox" name="active" <%= product?.active || !product ? 'checked' : '' %>> Produk aktif</label>
      <label class="check-line"><input type="checkbox" name="featured" <%= product?.featured ? 'checked' : '' %>> Tampilkan sebagai featured</label>
      <div class="full-span form-actions">
        <button class="btn btn-primary" type="submit">Simpan Produk</button>
        <a class="btn btn-secondary" href="/secure-admin-products-rmz9x">Kembali</a>
      </div>
    </form>
  </main>
</section>
</body>
</html>
