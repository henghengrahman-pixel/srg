<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title><%= mode === 'edit' ? 'Edit Produk' : 'Tambah Produk' %> - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><div class='admin-layout'><aside class='sidebar'><div class='brand'>Teman<span>Belanja</span></div><nav class='side-nav'><a href='/admin'>Dashboard</a><a class='active' href='/admin/products'>Kelola Produk</a><a href='/admin/products/new'>Tambah Produk</a><a href='/admin/articles'>Kelola Artikel</a><a href='/admin/articles/new'>Tulis Artikel</a><a href='/admin/logout'>Logout</a></nav></aside><main><div class='panel'><div class='section-head' style='margin-top:0'><div><h2><%= mode === 'edit' ? 'Edit Produk' : 'Tambah Produk Baru' %></h2><p>Lengkapi informasi agar halaman detail terlihat rapi, cantik, dan informatif.</p></div></div><form class='form' method='POST' enctype='multipart/form-data' action='<%= mode === "edit" ? "/admin/products/update/" + product.id : "/admin/products" %>'><div class='form-grid'><input name='title' placeholder='Nama produk' value='<%= product ? product.title : "" %>' required><select name='category'><option value=''>Pilih kategori</option><% categories.forEach(cat => { %><option value='<%= cat %>' <%= product && product.category === cat ? 'selected' : '' %>><%= cat %></option><% }) %></select></div><div class='form-grid'><input type='number' name='price' placeholder='Harga sekarang' value='<%= product ? product.price : "" %>'><input type='number' name='old_price' placeholder='Harga coret' value='<%= product ? product.old_price : "" %>'></div><input name='short_description' placeholder='Deskripsi singkat' value='<%= product ? product.short_description : "" %>'><textarea name='description' placeholder='Deskripsi lengkap produk'><%= product ? product.description : "" %></textarea><div class='form-grid'><input name='size_info' placeholder='Ukuran, contoh: S, M, L, XL' value='<%= product ? product.size_info : "" %>'><input name='color_info' placeholder='Warna, contoh: Hitam, Cream' value='<%= product ? product.color_info : "" %>'></div><div class='form-grid'><input name='material' placeholder='Material' value='<%= product ? product.material : "" %>'><input name='weight' placeholder='Berat' value='<%= product ? product.weight : "" %>'></div><div class='form-grid'><div><input type='file' name='image' accept='image/*'><div class='small-note'>Upload gambar manual</div></div><div><input name='image_url' placeholder='Atau masukkan link gambar' value='<%= product ? product.image_url : "" %>'><div class='small-note'>Link gambar manual</div></div></div><div class='form-grid'><div><input type='file' name='video' accept='video/*'><div class='small-note'>Upload video manual</div></div><div><input name='video_url' placeholder='Atau masukkan link video/embed' value='<%= product ? product.video_url : "" %>'><div class='small-note'>Link video manual</div></div></div><input name='affiliate' placeholder='Link tujuan tombol beli / lanjut ke toko' value='<%= product ? product.affiliate : "" %>' required><div class='top-actions'><button type='submit' class='btn'><%= mode === 'edit' ? 'Update Produk' : 'Simpan Produk' %></button><a href='/admin/products' class='btn-secondary'>Kembali</a></div></form></div></main></div></div></body></html>