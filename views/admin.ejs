<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Dashboard Admin - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><div class='admin-layout'><aside class='sidebar'><div class='brand'>Teman<span>Belanja</span></div><nav class='side-nav'><a class='active' href='/admin'>Dashboard</a><a href='/admin/products'>Kelola Produk</a><a href='/admin/products/new'>Tambah Produk</a><a href='/admin/articles'>Kelola Artikel</a><a href='/admin/articles/new'>Tulis Artikel</a><a href='/admin/logout'>Logout</a></nav></aside><main><div class='panel'><div class='admin-top'><div><h1 style='font-size:32px;margin-bottom:6px'>Halo, <%= adminUsername %></h1><p class='muted'>Kelola tampilan katalog, halaman detail, dan artikel dengan gaya premium.</p></div><div class='top-actions'><a class='btn' href='/admin/products/new'>Tambah Produk</a><a class='btn-secondary' href='/admin/articles/new'>Tulis Artikel</a></div></div><section class='stats'><div class='stat-card'><h3>Total Produk</h3><div class='num'><%= productCount %></div></div><div class='stat-card'><h3>Total Artikel</h3><div class='num'><%= articleCount %></div></div></section></div><div class='section-head'><div><h2>Produk Terbaru</h2><p>Konten terbaru yang tampil di halaman publik.</p></div><a class='nav-btn' href='/admin/products'>Lihat Semua</a></div><% if (latestProducts.length === 0) { %><div class='empty'>Belum ada produk.</div><% } else { %><div class='table-list'><% latestProducts.forEach(p => { %><div class='item-row'><div class='item-thumb'><% if (p.image) { %><img src='/uploads/<%= p.image %>' alt='<%= p.title %>'><% } else if (p.image_url) { %><img src='<%= p.image_url %>' alt='<%= p.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1541099649105-f69ad21f3246?auto=format&fit=crop&w=500&q=80' alt='<%= p.title %>'><% } %></div><div class='item-content'><h3><%= p.title %></h3><p><%= p.category || '-' %> • Rp <%= Number(p.price || 0).toLocaleString('id-ID') %></p></div><div class='item-actions'><a class='btn' href='/admin/products/edit/<%= p.id %>'>Edit</a><form method='POST' action='/admin/products/delete/<%= p.id %>' data-confirm='Hapus produk ini?'><button class='btn-danger' type='submit'>Hapus</button></form></div></div><% }) %></div><% } %><div class='section-head'><div><h2>Artikel Terbaru</h2><p>Artikel untuk memperkaya tampilan halaman publik.</p></div><a class='nav-btn' href='/admin/articles'>Lihat Semua</a></div><% if (latestArticles.length === 0) { %><div class='empty'>Belum ada artikel.</div><% } else { %><div class='table-list'><% latestArticles.forEach(a => { %><div class='item-row'><div class='item-thumb'><% if (a.thumbnail) { %><img src='/uploads/<%= a.thumbnail %>' alt='<%= a.title %>'><% } else if (a.thumbnail_url) { %><img src='<%= a.thumbnail_url %>' alt='<%= a.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=500&q=80' alt='<%= a.title %>'><% } %></div><div class='item-content'><h3><%= a.title %></h3><p><%= a.excerpt || 'Artikel terbaru untuk halaman publik.' %></p></div><div class='item-actions'><a class='btn' href='/admin/articles/edit/<%= a.id %>'>Edit</a><form method='POST' action='/admin/articles/delete/<%= a.id %>' data-confirm='Hapus artikel ini?'><button class='btn-danger' type='submit'>Hapus</button></form></div></div><% }) %></div><% } %></main></div></div><script src='/public/main.js'></script></body></html>