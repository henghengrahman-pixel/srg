<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Admin - TemanBelanja</title>
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>
  <div class="container">
    <div class="admin-header">
      <div>
        <div class="brand">TemanBelanja</div>
        <div class="small-text">Dashboard Admin Produk Affiliate</div>
      </div>
      <a href="/admin/logout" class="nav-btn">Logout</a>
    </div>

    <div class="panel">
      <h2 class="section-title">Tambah Produk</h2>

      <form method="POST" action="/admin/product" enctype="multipart/form-data" class="form">
        <input name="title" placeholder="Nama Produk" required>
        <input name="category" placeholder="Kategori, contoh: Skincare">
        <input name="price" type="number" placeholder="Harga">
        <input name="affiliate" placeholder="Link Affiliate Shopee" required>
        <input type="file" name="image" accept="image/*">
        <button type="submit">Simpan Produk</button>
      </form>
    </div>

    <h2 class="section-title">Daftar Produk</h2>

    <% if (products.length === 0) { %>
      <div class="empty">Belum ada produk.</div>
    <% } %>

    <div class="grid">
      <% products.forEach(p => { %>
        <div class="card">
          <% if (p.image) { %>
            <img src="/uploads/<%= p.image %>" alt="<%= p.title %>">
          <% } else { %>
            <img src="https://via.placeholder.com/400x300?text=TemanBelanja" alt="No image">
          <% } %>

          <div class="card-body">
            <h3><%= p.title %></h3>
            <div class="meta">Kategori: <%= p.category || '-' %></div>
            <div class="price">Rp <%= Number(p.price || 0).toLocaleString('id-ID') %></div>
            <a href="<%= p.affiliate %>" target="_blank" class="buy-btn">Lihat Link Shopee</a>

            <form method="POST" action="/admin/product/delete/<%= p.id %>">
              <button type="submit" class="delete-btn">Hapus Produk</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
