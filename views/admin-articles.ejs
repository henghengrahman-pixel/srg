<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Kelola Artikel - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><div class='admin-layout'><aside class='sidebar'><div class='brand'>Teman<span>Belanja</span></div><nav class='side-nav'><a href='/admin'>Dashboard</a><a href='/admin/products'>Kelola Produk</a><a href='/admin/products/new'>Tambah Produk</a><a class='active' href='/admin/articles'>Kelola Artikel</a><a href='/admin/articles/new'>Tulis Artikel</a><a href='/admin/logout'>Logout</a></nav></aside><main><div class='section-head'><div><h2>Kelola Artikel</h2><p>Tulis artikel cantik dan informatif untuk membuat halaman publik lebih hidup.</p></div><a class='btn' href='/admin/articles/new'>Tulis Artikel</a></div><% if (articles.length === 0) { %><div class='empty'>Belum ada artikel.</div><% } else { %><div class='table-list'><% articles.forEach(a => { %><div class='item-row'><div class='item-thumb'><% if (a.thumbnail) { %><img src='/uploads/<%= a.thumbnail %>' alt='<%= a.title %>'><% } else if (a.thumbnail_url) { %><img src='<%= a.thumbnail_url %>' alt='<%= a.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=600&q=80' alt='<%= a.title %>'><% } %></div><div class='item-content'><h3><%= a.title %></h3><p><%= a.excerpt || 'Artikel website.' %></p></div><div class='item-actions'><a class='btn' href='/admin/articles/edit/<%= a.id %>'>Edit</a><form method='POST' action='/admin/articles/delete/<%= a.id %>' data-confirm='Hapus artikel ini?'><button type='submit' class='btn-danger'>Hapus</button></form></div></div><% }) %></div><% } %></main></div></div><script src='/public/main.js'></script></body></html>