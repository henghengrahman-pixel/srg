<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Artikel - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><header class='topbar'><div class='brand'>Teman<span>Belanja</span></div><div class='top-actions'><a class='nav-btn' href='/'>Beranda</a><a class='btn-secondary' href='/admin/login'>Admin</a></div></header><div class='section-head'><div><h2>Artikel</h2><p>Konten cantik dan informatif untuk memperkaya pengalaman pengunjung.</p></div></div><% if (articles.length === 0) { %><div class='empty'>Belum ada artikel.</div><% } %><section class='article-grid'><% articles.forEach(article => { %><article class='article-card'><% if (article.thumbnail) { %><img src='/uploads/<%= article.thumbnail %>' alt='<%= article.title %>'><% } else if (article.thumbnail_url) { %><img src='<%= article.thumbnail_url %>' alt='<%= article.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=1200&q=80' alt='<%= article.title %>'><% } %><div class='article-body'><h3><%= article.title %></h3><p><%= article.excerpt || 'Artikel dengan layout modern dan elegan.' %></p><a class='btn' href='/articles/<%= article.slug %>'>Baca Selengkapnya</a></div></article><% }) %></section></div></body></html>