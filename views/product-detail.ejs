<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title><%= product.title %> - TemanBelanja</title><meta name='description' content='<%= product.short_description || product.title %>'><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><header class='topbar'><div class='brand'>Teman<span>Belanja</span></div><div class='top-actions'><a class='nav-btn' href='/'>Beranda</a><a class='btn-secondary' href='/articles'>Artikel</a></div></header><div class='breadcrumb'><a href='/'>Beranda</a> / <span><%= product.category || 'Produk' %></span> / <b><%= product.title %></b></div><section class='detail-wrap'><div class='detail-media'><% if (product.image) { %><img src='/uploads/<%= product.image %>' alt='<%= product.title %>'><% } else if (product.image_url) { %><img src='<%= product.image_url %>' alt='<%= product.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=1200&q=80' alt='<%= product.title %>'><% } %><% if (product.video) { %><div class='video-box'><video controls><source src='/uploads/<%= product.video %>'></video></div><% } else if (product.video_url) { %><div class='video-box embed-video'><iframe src='<%= product.video_url %>' allowfullscreen></iframe></div><% } %></div><div class='detail-info'><div class='meta-pill'><%= product.category || 'Pilihan' %></div><h1><%= product.title %></h1><p class='detail-sub'><%= product.short_description || 'Halaman detail yang rapi dan elegan untuk menampilkan informasi produk secara lengkap.' %></p><div class='price-row'><div class='price'>Rp <%= Number(product.price || 0).toLocaleString('id-ID') %></div><% if (Number(product.old_price || 0) > 0) { %><div class='old-price'>Rp <%= Number(product.old_price || 0).toLocaleString('id-ID') %></div><% } %></div><div class='spec-list'><div class='spec-item'><b>Ukuran</b><span><%= product.size_info || '-' %></span></div><div class='spec-item'><b>Warna</b><span><%= product.color_info || '-' %></span></div><div class='spec-item'><b>Material</b><span><%= product.material || '-' %></span></div><div class='spec-item'><b>Berat</b><span><%= product.weight || '-' %></span></div></div><a class='btn' style='width:100%;margin-top:8px' href='<%= product.affiliate %>' target='_blank' rel='noopener noreferrer'>Lanjut ke Toko</a></div></section><section class='content-card'><h2>Deskripsi Produk</h2><p><%= product.description || 'Belum ada deskripsi lengkap untuk produk ini.' %></p></section><div class='section-head'><div><h2>Produk Terkait</h2><p>Pilihan lain dalam kategori serupa.</p></div></div><% if (related.length === 0) { %><div class='empty'>Belum ada produk terkait.</div><% } else { %><section class='grid'><% related.forEach(p => { %><article class='card'><div class='card-media'><% if (p.image) { %><img src='/uploads/<%= p.image %>' alt='<%= p.title %>'><% } else if (p.image_url) { %><img src='<%= p.image_url %>' alt='<%= p.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1512436991641-6745cdb1723f?auto=format&fit=crop&w=900&q=80' alt='<%= p.title %>'><% } %></div><div class='card-body'><h3 class='card-title'><%= p.title %></h3><div class='price'>Rp <%= Number(p.price || 0).toLocaleString('id-ID') %></div><a class='btn' href='/product/<%= p.slug %>'>Lihat Detail</a></div></article><% }) %></section><% } %></div></body></html>