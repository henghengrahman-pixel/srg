<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TemanBelanja</title>
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>
  <div class="container">
    <div class="topbar">
      <div class="brand">TemanBelanja</div>
      <a href="/admin/login" class="nav-btn">Admin Login</a>
    </div>

    <div class="hero">
      <h2>Temukan Produk Pilihan & Belanja Langsung di Shopee</h2>
      <p>
        TemanBelanja adalah website affiliate yang menampilkan produk pilihan
        dari berbagai kategori. Klik produk favoritmu dan lanjut checkout di Shopee.
      </p>
    </div>

    <% if (products.length === 0) { %>
      <div class="empty">
        Belum ada produk. Tambahkan dulu dari dashboard admin.
      </div>
    <% } %>

    <div class="grid">
      <% products.forEach(p => { %>
        <div class="card">
          <% if (p.image) { %>
            <img src="/uploads/<%= p.image %>" alt="<%= p.title %>">
          <% } else { %>
            <img src="https://via.placeholder.com/400x300?text=TemanBelanja" alt="No image">
          <% } %>

          <div class="card-body">
            <h3><%= p.title %></h3>
            <div class="meta">Kategori: <%= p.category || '-' %></div>
            <div class="price">Rp <%= Number(p.price || 0).toLocaleString('id-ID') %></div>
            <a href="<%= p.affiliate %>" target="_blank" rel="nofollow sponsored" class="buy-btn">
              Beli di Shopee
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
