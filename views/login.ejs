<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Login Admin - TemanBelanja</title><link rel="stylesheet" href="/public/style.css"></head><body><div class="login-wrap"><div class="form-card"><h1>Login Admin</h1><p>Masuk ke dashboard untuk mengelola produk, artikel, gambar, video, dan detail konten.</p><% if (error) { %><div class="error"><%= error %></div><% } %><form method="POST" action="/admin/login" class="form"><input type="text" name="username" placeholder="ID admin" required><input type="password" name="password" placeholder="Password admin" required><button type="submit" class="btn">Masuk Dashboard</button></form></div></div></body></html>