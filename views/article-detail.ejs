<!DOCTYPE html><html lang='id'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title><%= article.title %> - TemanBelanja</title><link rel='stylesheet' href='/public/style.css'></head><body><div class='container'><header class='topbar'><div class='brand'>Teman<span>Belanja</span></div><div class='top-actions'><a class='nav-btn' href='/'>Beranda</a><a class='btn-secondary' href='/articles'>Artikel</a></div></header><section class='content-card' style='margin-top:0'><% if (article.thumbnail) { %><img style='width:100%;max-height:420px;object-fit:cover;border-radius:18px;margin-bottom:18px' src='/uploads/<%= article.thumbnail %>' alt='<%= article.title %>'><% } else if (article.thumbnail_url) { %><img style='width:100%;max-height:420px;object-fit:cover;border-radius:18px;margin-bottom:18px' src='<%= article.thumbnail_url %>' alt='<%= article.title %>'><% } %><h1 style='font-size:40px;line-height:1.1;margin-bottom:12px'><%= article.title %></h1><p class='muted' style='margin-bottom:16px'><%= article.excerpt || 'Artikel informatif untuk membuat situs tampil hidup dan profesional.' %></p><p><%= article.content || '-' %></p></section><div class='section-head'><div><h2>Artikel Lainnya</h2></div></div><% if (latest.length === 0) { %><div class='empty'>Belum ada artikel lain.</div><% } else { %><section class='article-grid'><% latest.forEach(a => { %><article class='article-card'><% if (a.thumbnail) { %><img src='/uploads/<%= a.thumbnail %>' alt='<%= a.title %>'><% } else if (a.thumbnail_url) { %><img src='<%= a.thumbnail_url %>' alt='<%= a.title %>'><% } else { %><img src='https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=1200&q=80' alt='<%= a.title %>'><% } %><div class='article-body'><h3><%= a.title %></h3><p><%= a.excerpt || 'Baca artikel lainnya.' %></p><a class='btn' href='/articles/<%= a.slug %>'>Baca</a></div></article><% }) %></section><% } %></div></body></html>